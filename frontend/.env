# AfconPulse — Frontend Environment Variables
# ─────────────────────────────────────────────
# LOCAL DEV:
# Leave this blank — vite.config.js proxy will forward /api → localhost:8000
# So you don't need to set anything for local development.
VITE_API_URL=

# PRODUCTION (uncomment and fill in after Railway deploy):
# VITE_API_URL=https://afcon-pulse-api.onrender.com
